DB_URL=postgres://cybersim:turtlerock@localhost:5432/cybersim
PORT=3001
NODE_ENV=development
LOG_LEVEL=error

IMPORT_PASSWORD=

# --- Airtable import (only needed when running `npm run import:scenario`) ---
AIRTABLE_ACCESS_TOKEN=patXXXXXXX
# Comma-separated slug:baseId pairs. One PAT can cover multiple bases.
# Example: AIRTABLE_BASE_IDS=cso:appXXXXXX,tnr:appYYYYYY
AIRTABLE_BASE_IDS=cso:appXXXXXX
# Default scenario slug for `npm run import:scenario` (so you don't pass --slug
# each time). Must exist in AIRTABLE_BASE_IDS. This ONLY affects the import
# script — it has nothing to do with which scenario games run as at runtime.
IMPORT_SCENARIO_SLUG=cso

# --- CORS ---
# Comma-separated list of frontend origins allowed to access the API.
# No trailing slashes.
#   Local:       UI_ORIGINS=http://localhost:3000
#   Production:  UI_ORIGINS=https://cso.cybersim.app,https://tnr.cybersim.app
UI_ORIGINS=http://localhost:3000

# NOTE: there is intentionally NO backend-wide scenario variable. The backend
# is multi-scenario — each game is bound to the scenario the frontend requests
# (subdomain in prod, REACT_APP_SCENARIO_SLUG in dev) and every request is
# scoped to its scenario. See README "Multi-Scenario Architecture".

DB_URL=postgres://cybersim:turtlerock@localhost:5432/cybersim
PORT=3001
NODE_ENV=development
LOG_LEVEL=error
IMPORT_PASSWORD=
AIRTABLE_ACCESS_TOKEN=patXXXXXXX
# Comma-separated slug:baseId pairs. One PAT can cover multiple bases.
# Example: AIRTABLE_BASE_IDS=cso:appXXXXXX,tnr:appYYYYYY
AIRTABLE_BASE_IDS=cso:appXXXXXX
# Optional: default slug for `npm run import:scenario` (avoids passing --slug each time).
IMPORT_SCENARIO_SLUG=cso

# Comma-separated list of frontend origins allowed to access the API.
# Used for CORS configuration in Express and Socket.IO.
# Do NOT include trailing slashes.
#
# For local development, include the React dev server origin:
# UI_ORIGINS=http://localhost:3000
#
# For production:
# UI_ORIGINS=https://cso.cybersim.app,https://tnr.cybersim.app
UI_ORIGINS=http://localhost:3000


# If running Airtable imports, this selects which scenario slug to import.
# The slug must exist in AIRTABLE_BASE_IDS, e.g. city:appXXXX.
IMPORT_SCENARIO_SLUG=city

# Runtime fallback scenario for backend game creation in local/dev mode.
# Must match REACT_APP_SCENARIO_SLUG in CyberSim-UI.
SCENARIO_SLUG=city

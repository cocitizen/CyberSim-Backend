{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Backend",
      "program": "${workspaceFolder}/index.js",
      "restart": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_OPTIONS": "-r dotenv/config"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Tests",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "DOTENV_CONFIG_PATH": ".env.test"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug DataSet Seed With DB Reset",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "reset-db:dataset"],
      "env": {
        "SEED_TAG": "cso@2026-03-03.1"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ]
}
